{
  "name": "gifmonster",
  "version": "0.1.0",
  "description": "Node.js native bindings for gifmonster",
  "license": "MIT OR Apache-2.0",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "gif",
    "encoder",
    "napi",
    "native",
    "rust",
    "animation",
    "video"
  ],
  "repository": {
    "type": "git",
